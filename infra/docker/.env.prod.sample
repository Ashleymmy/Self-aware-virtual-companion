# Example production config for `infra/docker/.env.prod`
# Safe to commit: this file contains placeholders only, no real secrets.
#
# Usage:
# 1. cp infra/docker/.env.prod.sample infra/docker/.env.prod
# 2. mkdir -p infra/docker/secrets
# 3. write real secrets into infra/docker/secrets/*
# 4. bash scripts/infra/prod_container.sh validate
# 5. bash scripts/infra/prod_container.sh up

# Host-side secret mount
SAVC_HOST_SECRETS_DIR=./secrets
SAVC_SECRETS_MOUNT=/run/savc-secrets
OPENCLAW_HOST_CREDENTIALS_DIR=./bootstrap/empty-credentials
SAVC_HOST_CODEX_HOME_DIR=./bootstrap/empty-codex-home
SAVC_HOST_DEV_WORKSPACE_DIR=./bootstrap/empty-workspace

# Public ports
OPENCLAW_GATEWAY_PORT=18789
SAVC_UI_PORT=5174

# UI runtime
VITE_SAVC_GATEWAY_URL=/gateway
VITE_SAVC_SESSION_KEY=main
SAVC_GATEWAY_INTERNAL_URL=http://savc-gateway:18789
SAVC_REDIS_URL=
MYSQL_URL=

# Gateway / app behavior
SAVC_AUTODEV_ENABLE=0
SAVC_CODEX_ACP_ENABLE=0
SAVC_CODEX_ACP_CWD=/workspace-devrepo
SAVC_CODEX_ACP_AGENT=codex
SAVC_CODEX_ACP_COMMAND=codex-acp
SAVC_CODEX_ACP_PERMISSION_MODE=approve-all
SAVC_CODEX_ACP_NON_INTERACTIVE=fail

# Default model provider example: Volces only
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCES_MODEL=doubao-seed-1-8-251228

# Optional proactive features
GOOGLE_CALENDAR_ID=
OPENWEATHER_LAT=
OPENWEATHER_LON=

# Required secret files
OPENCLAW_GATEWAY_TOKEN_FILE=/run/savc-secrets/openclaw_gateway_token

# At least one provider secret must be configured in production.
# This example uses Volces as the only active provider.
OPENAI_API_KEY_FILE=
ANTHROPIC_API_KEY_FILE=
ANYROUTER_API_KEY_FILE=
WZW_API_KEY_FILE=
GGBOOM_API_KEY_FILE=
CODE_API_KEY_FILE=
LAOYOU_API_KEY_FILE=
VOLCES_API_KEY_FILE=/run/savc-secrets/volces_api_key
SILICON_EMBEDDING_API_KEY_FILE=

# Optional channel secret files
DISCORD_BOT_TOKEN_FILE=
TELEGRAM_BOT_TOKEN_FILE=

# Optional proactive secret files
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON_FILE=
OPENWEATHER_API_KEY_FILE=

# Optional examples:
# If you enable Codex ACP, also set:
# SAVC_CODEX_ACP_ENABLE=1
# OPENAI_API_KEY_FILE=/run/savc-secrets/openai_api_key
#
# If you enable Discord proactive messaging, also set:
# DISCORD_BOT_TOKEN_FILE=/run/savc-secrets/discord_bot_token
#
# If you enable weather automation, also set:
# OPENWEATHER_LAT=31.2304
# OPENWEATHER_LON=121.4737
# OPENWEATHER_API_KEY_FILE=/run/savc-secrets/openweather_api_key
