FROM node:22-bookworm

RUN corepack enable
RUN npm install -g @openai/codex@0.114.0 @zed-industries/codex-acp@0.10.0

WORKDIR /workspace

COPY . /workspace

ENV NODE_ENV=production

ARG OPENCLAW_DOCKER_SKIP_CHOWN="0"
RUN if [ "${OPENCLAW_DOCKER_SKIP_CHOWN}" != "1" ]; then chown -R node:node /workspace; fi

USER node

CMD ["bash", "-lc", "corepack enable && OPENCLAW_ROOT_RUNTIME=\"${OPENCLAW_ROOT:-/workspace/node_modules/.pnpm/node_modules/openclaw}\" && if [ ! -f \"$OPENCLAW_ROOT_RUNTIME/openclaw.mjs\" ]; then pnpm --dir /workspace install --no-frozen-lockfile --lockfile=false; fi && mkdir -p /home/node/.openclaw && bash /workspace/scripts/setup.sh && exec node \"$OPENCLAW_ROOT_RUNTIME/openclaw.mjs\" gateway --bind lan --port ${OPENCLAW_GATEWAY_PORT:-18789}"]
