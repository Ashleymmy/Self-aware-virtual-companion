# Copy to infra/docker/.env before running container commands.
# Do not commit infra/docker/.env (it may contain secrets).

# Docker image and ports
SAVC_GATEWAY_IMAGE=savc-openclaw:dev
OPENCLAW_GATEWAY_PORT=18789
SAVC_UI_PORT=5174

# Gateway auth
OPENCLAW_GATEWAY_TOKEN=<set-in-local-env>
OPENCLAW_HOST_CREDENTIALS_DIR=./bootstrap/empty-credentials

# Optional provider keys (set what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANYROUTER_API_KEY=
WZW_API_KEY=
GGBOOM_API_KEY=
CODE_API_KEY=
LAOYOU_API_KEY=
VOLCES_API_KEY=
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCES_MODEL=doubao-seed-1-8-251228
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_CHAT_ID=
SILICON_EMBEDDING_API_KEY=

# SAVC UI runtime
VITE_SAVC_GATEWAY_URL=http://127.0.0.1:18789
VITE_SAVC_GATEWAY_TOKEN=
VITE_SAVC_SESSION_KEY=main
SAVC_REDIS_URL=
MYSQL_URL=

# Proactive engine (used when enabling the `automation` profile)
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
OPENWEATHER_API_KEY=
OPENWEATHER_LAT=
OPENWEATHER_LON=
