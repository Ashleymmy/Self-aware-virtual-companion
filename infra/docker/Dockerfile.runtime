FROM node:22-bookworm

RUN corepack enable

WORKDIR /workspace

COPY . /workspace

RUN pnpm -C /workspace/openclaw install --frozen-lockfile \
 && pnpm -C /workspace/openclaw exec tsdown --no-clean \
 && pnpm install --frozen-lockfile

ENV NODE_ENV=production

ARG SAVC_RUNTIME_SKIP_CHOWN="0"
RUN if [ "${SAVC_RUNTIME_SKIP_CHOWN}" != "1" ]; then chown -R node:node /workspace; fi

USER node
