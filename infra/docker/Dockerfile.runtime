FROM node:22-bookworm

RUN corepack enable

WORKDIR /workspace

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY savc-ui/package.json ./savc-ui/package.json

RUN pnpm install --frozen-lockfile

COPY . /workspace

ENV NODE_ENV=production

ARG SAVC_RUNTIME_SKIP_CHOWN="0"
RUN if [ "${SAVC_RUNTIME_SKIP_CHOWN}" != "1" ]; then chown -R node:node /workspace; fi

USER node
